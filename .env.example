# AeroMind Compliance - Local Development Environment Example
# DO NOT COMMIT THE ACTUAL .env FILE

# 1. Security (Mandatory)
JWT_SECRET=generate-a-secure-key-here-for-local-dev

# 2. LLM Configuration
GEMINI_API_KEY=your-api-key-here
LLM_MODEL_NAME=gemini-2.5-flash

# 3. Database (Defaults are set in docker-compose.yml)
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_URI=bolt://neo4j:7687

# 4. Networking
BACKEND_URL=http://python-backend:8000
PORT=3000
